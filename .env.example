# Crowd AI Mission Control environment

DEMO_NAME=crowd-ai-mission-control
DEMO_MODE=development

# Single-app MVP
APP_HOST=127.0.0.1
APP_PORT=3200
PUBLIC_DEMO_URL=http://127.0.0.1:3200

# QR / phone mode for rehearsal only. Use deliberately.
VISITOR_HOST=0.0.0.0
VISITOR_PORT=3200

# Optional split services
QR_BACKEND_HOST=127.0.0.1
QR_BACKEND_PORT=8200
MODEL_ADAPTER_URL=http://127.0.0.1:8600
REPLAY_SERVICE_URL=http://127.0.0.1:8700
HEALTH_STATUS_URL=http://127.0.0.1:8800

# External local model runtime, if used later
OLLAMA_URL=http://127.0.0.1:11434
VLLM_OPENAI_BASE_URL=http://127.0.0.1:8000/v1

# Public demo safety defaults
ALLOW_VISITOR_FREE_TEXT=false
STORE_VISITOR_INPUT=false
MODEL_TIMEOUT_SECONDS=3
FALLBACK_ON_MODEL_ERROR=true
